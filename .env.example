# Copy to `.env` (and optionally `.env.local`) for local development — see README.
# Production does not commit secrets; hosts inject DATABASE_URL / SECRET_KEY_BASE / PHX_HOST (see runtime.exs).

# --- Development database (Docker Compose defaults shown) ---
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=owlgate_dev

# Optional overrides
# DATABASE_URL=
