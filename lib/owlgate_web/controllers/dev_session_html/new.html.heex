<Layouts.app flash={@flash} current_user={@current_user} dev_routes={true}>
  <div class="max-w-xl space-y-6">
    <div>
      <h1 class="text-2xl font-semibold">Development sign-in</h1>
      <p class="text-sm text-base-content/70 mt-2">
        Impersonates a user by id for local use only — not a production authentication flow.
      </p>
    </div>

    <form action="/dev/session" method="post" class="grid gap-3">
      <input type="hidden" name="_csrf_token" value={@csrf_token} />
      <label class="form-control w-full">
        <span class="label-text text-sm">User</span>
        <select name="user_id" class="select select-bordered w-full" required>
          <option disabled selected value="">Select user…</option>
          <%= for u <- @users do %>
            <option value={u.id}>
              {u.name} ({u.role}) · {u.email}
            </option>
          <% end %>
        </select>
      </label>
      <div class="flex gap-3 flex-wrap">
        <button type="submit" class="btn btn-primary btn-sm">
          Continue
        </button>
      </div>
    </form>

    <div :if={@current_user} class="pt-6 border-t border-base-300">
      <p class="text-sm text-base-content/70 mb-2">Currently: {@current_user.email}</p>
      <form action="/dev/session" method="post">
        <input type="hidden" name="_csrf_token" value={@csrf_token} />
        <input type="hidden" name="_method" value="delete" />
        <button type="submit" class="btn btn-outline btn-sm">
          Clear session
        </button>
      </form>
    </div>
  </div>
</Layouts.app>
